# Script de migración — Variables de entorno
# Copia este fichero como .env y rellena los valores

# Nombre del repositorio de Prismic (solo el nombre, no la URL completa)
PRISMIC_REPO=babymundi

# (Opcional) Activa bindings remotos: D1 + R2 reales de Cloudflare.
# Sin esto, D1 ya es remoto (por "remote":true en wrangler.jsonc) pero R2 es local.
# Ponlo a "true" para la migración final de producción.
# CLOUDFLARE_REMOTE=true
